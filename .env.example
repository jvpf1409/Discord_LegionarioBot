# Token del bot (Discord Developer Portal -> Bot -> Reset Token)
DISCORD_TOKEN=coloca_aqui_tu_token

# Opcional: ID de tu servidor de pruebas para que los comandos slash
# se sincronicen al instante (sin esto, la sincronización global puede tardar ~1 hora)
GUILD_ID=

# Opcional: canal donde el bot anunciará automáticamente cada evento o raid
# nueva, y rol que mencionará en el aviso. Usa IDs numéricos de Discord.
CANAL_AVISOS_ID=
ROL_AVISOS_ID=

# Opcional: zona horaria usada para interpretar la fecha/hora que se ingresa
# al crear un evento (nombre de la base de datos IANA).
# America/Santiago = hora de Chile (ajusta sola su propio horario de verano).
ZONA_HORARIA=America/Santiago

# Opcional (solo producción): connection string de una base de datos Postgres
# (ej. Supabase o Neon.tech, ambos con capa gratis). Si se define, el bot guarda
# los eventos ahí en vez de en data/eventos.json, para que sobrevivan a cada
# deploy en Render. Si se deja vacía, se usa el archivo JSON local (ideal para
# probar el bot en tu máquina). Formato: postgresql://usuario:password@host:puerto/basededatos
DATABASE_URL=
